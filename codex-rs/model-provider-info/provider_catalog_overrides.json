{
  "supported_provider_npm_packages": [
    "@ai-sdk/openai-compatible",
    "@ai-sdk/openai",
    "@ai-sdk/anthropic",
    "@openrouter/ai-sdk-provider",
    "@ai-sdk/groq"
  ],
  "include_provider_ids": [],
  "exclude_provider_ids": [
    "cloudflare-workers-ai",
    "lmstudio",
    "privatemode-ai"
  ],
  "api_base_url_overrides": {
    "groq": "https://api.groq.com/openai/v1",
    "anthropic": "https://api.anthropic.com"
  },
  "env_key_overrides": {
    "zai": "ZAI_API_KEY",
    "zai-coding-plan": "ZAI_API_KEY"
  },
  "live_model_sources": {
    "moonshotai": {
      "url": "https://api.moonshot.ai/v1/models",
      "auth": "bearer",
      "auth_env": ["MOONSHOT_API_KEY", "KIMI_API_KEY"]
    },
    "zai": {
      "url": "https://api.z.ai/api/paas/v4/models",
      "auth": "bearer",
      "auth_env": ["ZAI_API_KEY", "ZHIPU_API_KEY"]
    },
    "groq": {
      "url": "https://api.groq.com/openai/v1/models",
      "auth": "bearer",
      "auth_env": ["GROQ_API_KEY"],
      "filter_existing_to_live_ids": true,
      "append_new_models": false
    }
  },
  "provider_model_metadata_overrides": {
    "moonshotai": {
      "kimi-k3": {
        "thinking_toggle": true,
        "priority": -1
      },
      "kimi-k2.5": {
        "thinking_toggle": true
      },
      "kimi-k2.6": {
        "display_name": "Kimi K2.6",
        "description": "Tool calling; Image input",
        "reasoning": false,
        "input_modalities": ["text", "image"],
        "context_window": 262144,
        "priority": -1
      },
      "kimi-k2-0905-preview": {
        "priority": 1000
      }
    },
    "kimi-for-coding": {
      "k3": {
        "thinking_toggle": true,
        "priority": -1
      }
    },
    "moonshotai-cn": {
      "kimi-k2.5": {
        "thinking_toggle": true
      }
    }
  },
  "wire_api_overrides": {
    "anthropic": "messages",
    "kimi-for-coding": "chat",
    "moonshotai": "chat"
  },
  "sort_priorities": {
    "anthropic": 2,
    "openrouter": 20,
    "groq": 21,
    "github-models": 24,
    "opencode": 26,
    "opencode-go": 27,
    "github-copilot": 28,
    "poe": 29,
    "perplexity-agent": 30,
    "requesty": 31,
    "deepseek": 32,
    "moonshotai": 33,
    "moonshotai-cn": 34,
    "zhipuai": 35,
    "zai": 36,
    "siliconflow": 37,
    "siliconflow-cn": 38,
    "alibaba": 39,
    "alibaba-cn": 40,
    "stepfun": 41,
    "modelscope": 42,
    "qiniu-ai": 43,
    "jiekou": 44,
    "302ai": 45,
    "novita-ai": 46,
    "fireworks-ai": 47,
    "nvidia": 48,
    "huggingface": 49,
    "chutes": 50,
    "ollama-cloud": 51,
    "llama": 52,
    "upstage": 53,
    "nova": 54,
    "xiaomi": 55
  }
}
